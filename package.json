{
  "name": "flow-assist",
  "version": "0.4.0",
  "description": "FlowAssist — local task manager",
  "author": "k-sva",
  "license": "GPL-3.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --flowassist-debug",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.flowassist.app",
    "productName": "FlowAssist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "tasks.json",
      "data-schema.js",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "FlowAssist-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FlowAssist-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^36.8.1",
    "electron-builder": "^26.8.1"
  }
}

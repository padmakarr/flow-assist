{
  "name": "flow-assist",
  "version": "1.0.1",
  "description": "FlowAssist — local task manager",
  "author": "k-sva",
  "license": "GPL-3.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --flowassist-debug",
    "test:e2e": "playwright test --config tests/playwright.config.js",
    "test:ui-map": "playwright test --config tests/playwright.config.js tests/discovery/ui-mapper.spec.js",
    "test:regression": "playwright test --config tests/playwright.config.js tests/regression",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.flowassist.app",
    "productName": "FlowAssist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "reminder.html",
      "styles.css",
      "tasks.json",
      "data-schema.js",
      "package.json",
      "LICENSE",
      "README.md",
      "minigames/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "FlowAssist-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FlowAssist-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^36.8.1",
    "electron-builder": "^26.8.1"
  }
}
